<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Pratica_iReport" language="groovy" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.6500000000000008"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="Title" fontName="Arial" fontSize="26" isBold="true" pdfFontName="Helvetica-Bold"/>
	<style name="SubTitle" forecolor="#666666" fontName="Arial" fontSize="18"/>
	<style name="Column header" forecolor="#666666" fontName="Arial" fontSize="12" isBold="true"/>
	<style name="Detail" fontName="Arial" fontSize="12"/>
	<parameter name="P_DTNEGINI" class="java.sql.Timestamp">
		<parameterDescription><![CDATA[Dt. Negocio Inicio]]></parameterDescription>
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="P_DTNEGFIN" class="java.sql.Timestamp">
		<parameterDescription><![CDATA[Dt. Negocio Final]]></parameterDescription>
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="P_CODVEND" class="java.math.BigDecimal">
		<property name="nomeTabela" value="TGFVEN"/>
		<parameterDescription><![CDATA[Vendedor]]></parameterDescription>
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="P_GRUNAT" class="java.math.BigDecimal">
		<property name="nomeTabela" value="TGFGRU"/>
		<parameterDescription><![CDATA[Grupo de Natureza]]></parameterDescription>
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="P_CODPARC" class="java.math.BigDecimal">
		<property name="nomeTabela" value="TGFPAR"/>
		<parameterDescription><![CDATA[Parceiro]]></parameterDescription>
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="PDIR_MODELO" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
	ite.codprod,
	pro.descrprod,
	pro.marca,
	sum(ite.qtdneg) AS qtdneg,
	sum(ite.vlrtot - ite.vlrdesc) AS vlrtotalliq

FROM tgfcab cab
INNER JOIN tgfite ite ON cab.nunota = ite.nunota
INNER join tgftop top ON cab.codtipoper = top.CODTIPOPER AND cab.DHTIPOPER  = top.DHALTER
INNER JOIN tgfpro pro ON ite.CODPROD = pro.CODPROD

WHERE cab.dtneg BETWEEN trunc($P{P_DTNEGINI}) AND trunc($P{P_DTNEGFIN})
	AND top.golsinal =-1
	AND (cab.codvend = $P{P_CODVEND} OR $P{P_CODVEND} IS NULL)
	AND (pro.codgrupoprod = $P{P_GRUNAT} OR $P{P_GRUNAT} IS NULL)
	AND (cab.codparc = $P{P_CODPARC} OR $P{P_CODPARC} IS NULL)
GROUP BY
	ite.codprod,
	pro.descrprod,
	pro.marca
ORDER BY
	'vlrtotalliq' DESC]]>
	</queryString>
	<field name="CODPROD" class="java.math.BigDecimal"/>
	<field name="DESCRPROD" class="java.lang.String"/>
	<field name="MARCA" class="java.lang.String"/>
	<field name="QTDNEG" class="java.math.BigDecimal"/>
	<field name="VLRTOTALLIQ" class="java.math.BigDecimal"/>
	<variable name="V_VLRLIQTOT" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{VLRTOTALLIQ}.doubleValue()]]></variableExpression>
	</variable>
	<group name="Group1">
		<groupExpression><![CDATA[(int)($V{REPORT_COUNT}/15)]]></groupExpression>
	</group>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="90" splitType="Stretch">
			<staticText>
				<reportElement style="Title" x="0" y="13" width="263" height="33"/>
				<textElement verticalAlignment="Middle"/>
				<text><![CDATA[Vendas pro Produto]]></text>
			</staticText>
			<staticText>
				<reportElement style="SubTitle" x="117" y="46" width="157" height="22"/>
				<textElement/>
				<text><![CDATA[Mercado]]></text>
			</staticText>
			<image>
				<reportElement x="413" y="0" width="140" height="68"/>
				<imageExpression class="java.lang.String"><![CDATA[$P{PDIR_MODELO}+"Logo.jpg"]]></imageExpression>
			</image>
		</band>
	</title>
	<pageHeader>
		<band splitType="Stretch"/>
	</pageHeader>
	<columnHeader>
		<band height="36" splitType="Stretch">
			<rectangle>
				<reportElement x="0" y="0" width="553" height="35" backcolor="#CCCCCC"/>
			</rectangle>
			<line>
				<reportElement positionType="FixRelativeToBottom" x="0" y="35" width="555" height="1"/>
				<graphicElement>
					<pen lineWidth="0.5" lineColor="#999999"/>
				</graphicElement>
			</line>
			<staticText>
				<reportElement x="0" y="0" width="138" height="20"/>
				<textElement>
					<font size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[DESCRPROD]]></text>
			</staticText>
			<staticText>
				<reportElement x="138" y="0" width="138" height="20"/>
				<textElement textAlignment="Center">
					<font size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[MARCA]]></text>
			</staticText>
			<staticText>
				<reportElement x="276" y="0" width="138" height="20"/>
				<textElement textAlignment="Center">
					<font size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[QTDNEG]]></text>
			</staticText>
			<staticText>
				<reportElement x="414" y="0" width="138" height="20"/>
				<textElement textAlignment="Right">
					<font size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[VLRTOTALLIQ]]></text>
			</staticText>
		</band>
	</columnHeader>
	<detail>
		<band height="28" splitType="Stretch">
			<textField pattern="¤ #,##0.00">
				<reportElement x="415" y="8" width="138" height="20"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{VLRTOTALLIQ}]]></textFieldExpression>
			</textField>
			<line>
				<reportElement x="5" y="27" width="550" height="1"/>
				<graphicElement>
					<pen lineStyle="Dashed"/>
				</graphicElement>
			</line>
			<textField pattern="#,##0">
				<reportElement x="279" y="7" width="136" height="20"/>
				<textElement textAlignment="Center"/>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{QTDNEG}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="138" y="7" width="138" height="20"/>
				<textElement textAlignment="Center"/>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{MARCA}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="7" width="138" height="20"/>
				<textElement/>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{CODPROD}+" - "+$F{DESCRPROD}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<pageFooter>
		<band height="21" splitType="Stretch">
			<textField>
				<reportElement style="Column header" x="433" y="0" width="80" height="20"/>
				<textElement textAlignment="Right">
					<font size="10" isBold="false"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["Page "+$V{PAGE_NUMBER}+" of"]]></textFieldExpression>
			</textField>
			<textField evaluationTime="Report">
				<reportElement style="Column header" x="513" y="0" width="40" height="20"/>
				<textElement>
					<font size="10" isBold="false"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[" " + $V{PAGE_NUMBER}]]></textFieldExpression>
			</textField>
			<textField pattern="EEEEE dd MMMMM yyyy">
				<reportElement style="Column header" x="0" y="0" width="197" height="20"/>
				<textElement>
					<font size="10" isBold="false"/>
				</textElement>
				<textFieldExpression class="java.util.Date"><![CDATA[new java.util.Date()]]></textFieldExpression>
			</textField>
		</band>
	</pageFooter>
	<summary>
		<band height="28" splitType="Stretch">
			<textField pattern="¤ #,##0.00">
				<reportElement x="455" y="0" width="100" height="20"/>
				<box>
					<topPen lineWidth="1.0"/>
				</box>
				<textElement textAlignment="Right"/>
				<textFieldExpression class="java.lang.Double"><![CDATA[$V{V_VLRLIQTOT}]]></textFieldExpression>
			</textField>
		</band>
	</summary>
</jasperReport>
