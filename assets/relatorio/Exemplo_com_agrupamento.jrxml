<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="DemonstrativoCPRB" pageWidth="842" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.8150000000000004"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<subDataset name="Empresa">
		<queryString>
			<![CDATA[select
razaosocial,
cgc,
(case when codemp = 1 then 'Matriz' else 'Filial' end) as matriz,
to_char(sysdate, 'DD/MM/YYYY HH24:mm') as data_impressao

from tsiemp
where codemp = 1]]>
		</queryString>
		<field name="RAZAOSOCIAL" class="java.lang.String"/>
		<field name="CGC" class="java.lang.String"/>
		<field name="MATRIZ" class="java.lang.String"/>
		<field name="DATA_IMPRESSAO" class="java.lang.String"/>
	</subDataset>
	<parameter name="P_DHINICIO" class="java.sql.Timestamp">
		<parameterDescription><![CDATA[Data Inicio:]]></parameterDescription>
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="P_CODEMP" class="java.math.BigDecimal">
		<property name="nomeTabela" value="TSIEMP"/>
		<parameterDescription><![CDATA[Empresa:]]></parameterDescription>
	</parameter>
	<parameter name="P_DTFIN" class="java.sql.Timestamp">
		<parameterDescription><![CDATA[Data Final:]]></parameterDescription>
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[with base as (
select
ite.codprod||' - '||pro.descrprod as produto,
ite.codcfo as cfop,
ite.codtrib as CST,
ite.qtdneg as quatidade,
ite.vlrtot as vlr_tot_item,
ite.baseicms as base_icms,
ite.aliqicms as aliq_icms,
ite.vlricms as vlr_aliq_icms,
pro.ncm,
cab.codemp
from tgfite ite
inner join tgfcab cab on ite.nunota = cab.nunota
inner join tgfpro pro on pro.codprod = ite.codprod
where cab.tipmov = 'C'
and pro.AD_RELADIESEL = 'S'
and (trunc(cab.dtneg) >= $P{P_DHINICIO} or $P{P_DHINICIO} is null)
and (trunc(cab.dtneg) <= $P{P_DTFIN} or $P{P_DTFIN} is null)
)
SELECT * FROM (
select 'bloco1' as bloco, produto as prodb, cfop as cfopb, CST as cstb,
    sum(quatidade) as quatidadeb, sum(vlr_tot_item) as vlr_tot_itemb,
    base_icms as base_icmb, aliq_icms as aliq_icmsb, vlr_aliq_icms as vlr_aliq_icmsb,
    null as ncm, null as razaosocial, null as cgc, null as matriz, null as data_impressao
from base
where codemp = $P{P_CODEMP}
group by produto, cfop, CST, base_icms, aliq_icms, vlr_aliq_icms

UNION ALL

select 'bloco2' as bloco, null, null, CST as cstb,
    sum(quatidade), sum(vlr_tot_item),
    base_icms, null, vlr_aliq_icms,
    null, null, null, null, null
from base
where codemp = $P{P_CODEMP}
group by CST, base_icms, vlr_aliq_icms

UNION ALL

select 'bloco3' as bloco, null, cfop as cfopb, null,
    sum(quatidade), sum(vlr_tot_item),
    base_icms, null, vlr_aliq_icms,
    null, null, null, null, null
from base
where codemp = $P{P_CODEMP}
group by cfop, base_icms, vlr_aliq_icms

UNION ALL

select 'bloco4' as bloco, null, null, null,
    sum(quatidade), sum(vlr_tot_item),
    base_icms, aliq_icms, vlr_aliq_icms,
    null, null, null, null, null
from base
where codemp = $P{P_CODEMP}
group by base_icms, aliq_icms, vlr_aliq_icms

UNION ALL

select 'bloco5' as bloco, null, null, null,
    sum(quatidade), sum(vlr_tot_item),
    base_icms, null, vlr_aliq_icms,
    ncm as ncmb5, null, null, null, null
from base
where codemp = $P{P_CODEMP}
group by ncm, base_icms, vlr_aliq_icms

UNION ALL

select distinct 'Cabeçalho' as bloco,
    null, null, null, null, null, null, null, null, null,
    razaosocial, cgc,
    (case when codemp = 1 then 'Matriz' else 'Filial' end) as matriz,
    to_char(sysdate, 'DD/MM/YYYY HH24:mm') as data_impressao
from tsiemp
where codemp = $P{P_CODEMP}

ORDER BY bloco
)
ORDER BY
    CASE bloco
        WHEN 'Cabeçalho' THEN 0
        WHEN 'bloco1' THEN 1
        WHEN 'bloco2' THEN 2
        WHEN 'bloco3' THEN 3
        WHEN 'bloco4' THEN 4
        WHEN 'bloco5' THEN 5
        ELSE 6
    END]]>
	</queryString>
