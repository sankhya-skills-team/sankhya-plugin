	<subDataset name="Table Dataset 1">
		<parameter name="P_DTINI" class="java.sql.Timestamp">
			<parameterDescription><![CDATA[Data Inicial:]]></parameterDescription>
		</parameter>
		<parameter name="P_DTFIN" class="java.sql.Timestamp">
			<parameterDescription><![CDATA[Data Final:]]></parameterDescription>
		</parameter>
		<queryString>
			<![CDATA[/*Query Relatório PF Larifo*/
with empresa as (
select
emp.codemp,
emp.razaosocial as razaosocialemp,
emp.nomefantasia as nomefantasiaemp,
emp.cgc,
emp.inscestad,
emp.telefone as telefoneemp,
upper(endr.tipo||' '||endr.nomeend||', '||emp.numend||', '||cid.nomecid||' '||bai.nomebai) as enderecoemp,
uf.uf,
emp.email,
emp.cep,
cid.nomecid

from tsiemp emp
inner join tsiend endr on endr.codend = emp.codend
inner join tsibai bai on bai.codbai = emp.codbai
inner join tsicid cid on cid.codcid = emp.codcid
inner join tsiufs uf on uf.coduf = cid.uf
),
parceiro as (
select
par.codparc,
par.razaosocial,
par.cgc_cpf,
cid.nomecid||'/'||uf.uf as cidadeuf

from tgfpar par
left join tsicid cid on cid.codcid = par.codcid
inner join tsiufs uf on cid.uf = uf.coduf
)
select
emp.razaosocialemp,
emp.cgc,
emp.enderecoemp,
reme.razaosocial as remetente,
reme.cgc_cpf as cgcreme,
dest.razaosocial as destinatario,
dest.cgc_cpf as cgcdest,
nite.descrprod,
nvl(pro.ad_prodcas,' ') as ad_prodcas,
nvl(pro.ncm,' ') as ad_prodcodpf,
nite.codvol,
nite.qtdneg,
vei.placa,
mot.razaosocial,
reme.cidadeuf as origem,
dest.cidadeuf as destino,
to_char(ord.dhsaida,'DD/MM/YYYY HH24:mm') as dhsaida,
to_char(ord.dhprevcgd,'DD/MM/YYYY HH24:mm') as dhprevcgd,
ord.dtinclusao,
mdfe.descprod

from tgford ord
inner join tmsnotas notas on notas.nuordem = ord.nuordem
left join parceiro reme on reme.codparc = notas.codparcrem
left join parceiro dest on dest.codparc = notas.codparcdest
inner join tmsnotasite nite on nite.nrounico = notas.nrounico
inner join empresa emp on emp.codemp = ord.codemp
inner join tgfvei vei on vei.codveiculo = ord.codveiculo
left join parceiro mot on mot.codparc = ord.codparcmotorista
left join tgfmdfe mdfe on mdfe.nuviag = ord.nuviag
left join tgfpro pro on pro.descrprod = mdfe.descprod

where pro.AD_PRODCONTRPF = 'S'
and trunc(ord.dtinclusao) >= trunc($P{P_DTINI})
and trunc(ord.dtinclusao) <= trunc($P{P_DTFIN})]]>
		</queryString>
