<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Autorizacao_desconto_multas" language="groovy" pageWidth="595" pageHeight="842" columnWidth="454" leftMargin="56" rightMargin="85" topMargin="56" bottomMargin="56">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="P_FOLHA" class="java.sql.Timestamp">
		<parameterDescription><![CDATA[Folha de Desconto:]]></parameterDescription>
	</parameter>
	<parameter name="PK_NUREGMT" class="java.math.BigDecimal" isForPrompting="false">
		<parameterDescription><![CDATA[Nro Multa:]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[select
emp.razaosocial,
initcap(emp.razaosocial) as nomeemp,
coalesce(par.razaosocial,par.nomeparc) as nomeparc,
par.identinscestad,
par.codparc,
par.cgc_cpf,
fun.numcps,
uffun.uf as ufctp,
regexp_replace(emp.cgc,'(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})', '\1.\2.\3/\4-\5') as cgc,
mut.nrauto,
to_char(mut.vlrdescmot,'FM999999990D00', 'NLS_NUMERIC_CHARACTERS=,.') as vlrdescmot,
cid.nomecid,
uf.uf,
to_char($P{P_FOLHA},'fmmonth/YYYY') as folhadesc,
to_char(sysdate,'DD/MM/YYYY') as data,
SANKHYA.EXTENSO_MONETARIO(mut.vlrdescmot) as vlrextenso


from tcfmut mut
left join tgfpar par on par.codparc = mut.codparcmot
left join tsiemp emp on emp.codemp = mut.codemp
left join tfpfun fun on fun.cpf = par.cgc_cpf
left join tsicid cid on cid.codcid = mut.codcid
left join tsiufs uf on uf.coduf = cid.uf
left join tsiufs uffun on uffun.coduf = fun.ufcps

where mut.nuregmt = $P{PK_NUREGMT}]]>
	</queryString>
	<field name="RAZAOSOCIAL" class="java.lang.String"/>
	<field name="NOMEEMP" class="java.lang.String"/>
	<field name="NOMEPARC" class="java.lang.String"/>
	<field name="IDENTINSCESTAD" class="java.lang.String"/>
	<field name="CODPARC" class="java.math.BigDecimal"/>
	<field name="CGC_CPF" class="java.lang.String"/>
	<field name="NUMCPS" class="java.math.BigDecimal"/>
	<field name="UFCTP" class="java.lang.String"/>
	<field name="CGC" class="java.lang.String"/>
	<field name="NRAUTO" class="java.lang.String"/>
	<field name="VLRDESCMOT" class="java.lang.String"/>
	<field name="NOMECID" class="java.lang.String"/>
	<field name="UF" class="java.lang.String"/>
	<field name="FOLHADESC" class="java.lang.String"/>
	<field name="DATA" class="java.lang.String"/>
	<field name="VLREXTENSO" class="java.lang.String"/>
	<detail>
		<band height="669" splitType="Stretch">
			<textField>
				<reportElement x="249" y="133" width="201" height="20"/>
				<textElement textAlignment="Right">
					<font fontName="Arial" size="12"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["CAIBI, SC "+$F{DATA}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true">
				<reportElement stretchType="RelativeToBandHeight" x="3" y="173" width="450" height="292"/>
				<textElement textAlignment="Justified" lineSpacing="1_1_2" markup="html">
					<font fontName="Arial" size="12"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["A<br><u><b>"+$F{RAZAOSOCIAL}+"</b></u><br><br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Eu, <b>"+$F{NOMEPARC}+"</b>, portador do RG: "+$F{IDENTINSCESTAD}+", CPF nº <b>"+$F{CGC_CPF}+"</b>, CTPS nº <b>"+$F{NUMCPS}+"/ "+$F{UFCTP}+"</b>, por meio deste termo, <b>AUTORIZO a "+$F{NOMEEMP}+"</b>, CNPJ. <b>"+$F{CGC}+"</b>, efetuar o desconto da <b>MULTA DE TRÂNSITO</b> identificada com os seguintes <b>AUTO DE INFRAÇÃO: Nº "+$F{NRAUTO}+"</b> em anexo a este termo, a qual tem valor total de <b>R$ "+$F{VLRDESCMOT}+" ("+$F{VLREXTENSO}+")</b>, o qual será descontado na folha de pagamento de <b>"+$F{FOLHADESC}+"</b>. <br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<b>AUTORIZO</b> ainda, que, seja efetuada a quitação deste termo em caso de <b><u>rescisão contratual</u></b>, descontando-se das minhas verbas rescisórias o valor equivalente ao saldo devedor naquela data, independente do motivo do desligamento. <br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;E, para que produza seus efeitos legais, firmo e assino a presente declaração."]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement positionType="Float" x="52" y="537" width="318" height="56"/>
				<box>
					<topPen lineWidth="1.0"/>
				</box>
				<textElement textAlignment="Center">
					<font fontName="Arial" size="12"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{NOMEPARC}+"\n"+$F{CGC_CPF}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement positionType="Float" x="52" y="613" width="318" height="56"/>
				<box>
					<topPen lineWidth="1.0"/>
				</box>
				<textElement textAlignment="Center">
					<font fontName="Arial" size="14"/>
				</textElement>
				<text><![CDATA[LARIFO TRANSPORTES LTDA - MATRIZ
05.503.671/0001-43]]></text>
			</staticText>
			<staticText>
				<reportElement x="15" y="0" width="439" height="121"/>
				<textElement textAlignment="Center" lineSpacing="1_1_2">
					<font fontName="Arial" size="26" isBold="true"/>
				</textElement>
				<text><![CDATA[TERMO AUTORIZAÇÃO DESCONTO MULTA DE TRÂNSITO]]></text>
			</staticText>
		</band>
	</detail>
</jasperReport>
