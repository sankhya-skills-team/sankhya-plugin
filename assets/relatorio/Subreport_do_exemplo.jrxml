<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Pratica02_produtos_lista_prods" language="groovy" pageWidth="555" pageHeight="802" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.9487171000000143"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="PK_NUNOTA" class="java.math.BigDecimal" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
    PRO.DESCRPROD,
    ITE.QTDNEG,
    ITE.VLRUNIT,
    (ITE.VLRTOT - ITE.VLRDESC) AS VLRTOT,
    NVL(ITE.BASEICMS,0) AS BASEICMS,
    NVL(ITE.BASEIPI,0) AS BASEIPI

FROM TGFITE ITE
INNER JOIN TGFPRO PRO ON ITE.CODPROD = PRO.CODPROD

WHERE ITE.NUNOTA = $P{PK_NUNOTA}]]>
	</queryString>
	<field name="DESCRPROD" class="java.lang.String"/>
	<field name="QTDNEG" class="java.lang.Double"/>
	<field name="VLRUNIT" class="java.lang.Double"/>
	<field name="VLRTOT" class="java.math.BigDecimal"/>
	<field name="BASEICMS" class="java.math.BigDecimal"/>
	<field name="BASEIPI" class="java.math.BigDecimal"/>
	<variable name="V_CONTADOR" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[1]]></variableExpression>
	</variable>
	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="45" splitType="Stretch">
			<rectangle>
				<reportElement x="0" y="0" width="555" height="45" forecolor="#CCCCCC" backcolor="#CCCCCC">
					<printWhenExpression><![CDATA[$V{V_CONTADOR}.intValue() % 2 != 0 ? Boolean.TRUE : Boolean.FALSE]]></printWhenExpression>
				</reportElement>
				<graphicElement>
					<pen lineColor="#000000"/>
				</graphicElement>
			</rectangle>
			<textField>
				<reportElement x="0" y="0" width="93" height="45"/>
				<box>
					<topPen lineWidth="1.0"/>
					<leftPen lineWidth="1.0"/>
					<bottomPen lineWidth="1.0"/>
					<rightPen lineWidth="1.0"/>
				</box>
				<textElement verticalAlignment="Middle"/>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{DESCRPROD}]]></textFieldExpression>
			</textField>
			<textField pattern="###0">
				<reportElement x="93" y="0" width="92" height="45"/>
				<box>
					<topPen lineWidth="1.0"/>
					<leftPen lineWidth="1.0"/>
					<bottomPen lineWidth="1.0"/>
					<rightPen lineWidth="1.0"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression class="java.lang.Double"><![CDATA[$F{QTDNEG}]]></textFieldExpression>
			</textField>
			<textField pattern="¤ #,##0.00">
				<reportElement x="185" y="0" width="92" height="45"/>
				<box>
					<topPen lineWidth="1.0"/>
					<leftPen lineWidth="1.0"/>
					<bottomPen lineWidth="1.0"/>
					<rightPen lineWidth="1.0"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression class="java.lang.Double"><![CDATA[$F{VLRUNIT}]]></textFieldExpression>
			</textField>
			<textField pattern="¤ #,##0.00">
				<reportElement x="277" y="0" width="92" height="45"/>
				<box>
					<topPen lineWidth="1.0"/>
					<leftPen lineWidth="1.0"/>
					<bottomPen lineWidth="1.0"/>
					<rightPen lineWidth="1.0"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{VLRTOT}]]></textFieldExpression>
			</textField>
			<textField pattern="¤ #,##0.00">
				<reportElement x="369" y="0" width="92" height="45"/>
				<box>
					<topPen lineWidth="1.0"/>
					<leftPen lineWidth="1.0"/>
					<bottomPen lineWidth="1.0"/>
					<rightPen lineWidth="1.0"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{BASEICMS}]]></textFieldExpression>
			</textField>
			<textField pattern="¤ #,##0.00">
				<reportElement x="461" y="0" width="94" height="45"/>
				<box>
					<topPen lineWidth="1.0"/>
					<leftPen lineWidth="1.0"/>
					<bottomPen lineWidth="1.0"/>
					<rightPen lineWidth="1.0"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{BASEIPI}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
