	<detail>
		<band height="31" splitType="Stretch">
			<subreport>
				<reportElement key="Itens" x="0" y="8" width="802" height="23"/>
				<subreportParameter name="ID">
					<subreportParameterExpression><![CDATA[$F{ID}]]></subreportParameterExpression>
				</subreportParameter>
				<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
				<returnValue subreportVariable="VLRTOT_1" toVariable="TOTOS" calculation="Sum"/>
				<returnValue subreportVariable="VLRTOTLIQ" toVariable="TOT_LIQUIDO" calculation="Sum"/>
