	<style name="estilo_status" mode="Transparent" forecolor="#000000" backcolor="#FFFFFF" fontSize="14" isItalic="false" isUnderline="false">
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{STATUS}.intValue() <= 5]]></conditionExpression>
			<style forecolor="#FF0000" fontSize="14" isItalic="false" isUnderline="false"/>
		</conditionalStyle>
	</style>
	<parameter name="PK_ID" class="java.math.BigDecimal" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Users\\SANKHYA\\Documents\\Exemplo\\Orçamento - Novo\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="PDIR_MODELO" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
/*DADOS DA EMPRESA*/
EMP.RAZAOSOCIAL AS RAZAOSOCIAL_EMP,
Tim_Formataendereco(EEND.TIPO, EEND.NOMEEND, EMP.NUMEND, EMP.COMPLEMENTO, EBAI.NOMEBAI, NULL, NULL) AS ENDERECO_EMP,
ECID.NOMECID ||' - '|| EUF.UF AS CIDADE_EMP,
EMP.CEP AS CEP_EMP,
TIM_FORMATATELEFONE(EMP.TELEFONE) AS TELEFONE_EMP,
FORMATAR_CPF_CNPJ(EMP.CGC) AS CNPJ_EMP,
EMP.INSCESTAD AS INSCESTAD_EMP,
EMP.INSCMUN AS INSCMUN_EMP,
EMP.EMAIL AS EMAIL_EMP,
/*DADOS DO CLIENTE*/
OS.NUNOTA,
CAB.DTNEG,
PAR.RAZAOSOCIAL AS  RAZAOSOCIAL_PAR,
Tim_Formataendereco(END.TIPO, END.NOMEEND, PAR.NUMEND, PAR.COMPLEMENTO, BAI.NOMEBAI, NULL, NULL) AS ENDERECO_PAR,
CID.NOMECID ||' - '|| UF.UF AS CIDADE_PAR,
PAR.CEP AS CEP_PAR,
FORMATAR_CPF_CNPJ(PAR.CGC_CPF) CNPJ_PAR,
PAR.INSCESTADNAUF AS INSCESTAD_PAR,
PAR.INSCMUN AS INSCMUN_PAR,
VEN.APELIDO AS VENDEDOR,
TPV.DESCRTIPVENDA,
NVL(CTT.TELEFONE, PAR.TELEFONE) AS TELEFONE_PAR,
NVL(CTT.CELULAR, PAR.FAX) AS CELULAR_PAR,
CTT.NOMECONTATO AS CONTATO_PAR,
NVL(CTT.EMAIL, PAR.EMAIL) AS EMAIL_PAR,
/*DADOS DA OS*/
ROWNUM,
OS.ID,
OS.NUOS,
OS.DESCRNOTA,
OS.STATUS,
OS.REVISAO,
OS.OBSERVACAO
FROM AD_CONTROLEOS OS
LEFT JOIN TGFPRO PRO ON PRO.CODPROD = OS.CODITEM
LEFT JOIN TGFPAR PAR ON PAR.CODPARC = OS.CODPARC
LEFT JOIN TSIEND END ON END.CODEND = PAR.CODEND
LEFT JOIN TSIBAI BAI ON BAI.CODBAI = PAR.CODBAI
LEFT JOIN TSICID CID ON CID.CODCID = PAR.CODCID
LEFT JOIN TSIUFS UF ON UF.CODUF = CID.UF
LEFT JOIN TGFVEN VEN ON VEN.CODVEND = OS.VENDEDOR
LEFT JOIN TSIEMP EMP ON EMP.CODEMP = OS.CODEMP
LEFT JOIN TSIEND EEND ON EEND.CODEND = EMP.CODEND
LEFT JOIN TSIBAI EBAI ON EBAI.CODBAI = EMP.CODBAI
LEFT JOIN TSICID ECID ON ECID.CODCID = EMP.CODCID
LEFT JOIN TSIUFS EUF ON EUF.CODUF = ECID.UF
LEFT JOIN TGFCAB CAB ON CAB.NUNOTA = OS.NUNOTA
LEFT JOIN TGFTPV TPV ON TPV.CODTIPVENDA = OS.CODTIPVENDA AND TPV.DHALTER = (SELECT MAX(B.DHALTER) FROM TGFTPV B WHERE B.CODTIPVENDA = TPV.CODTIPVENDA AND B.DHALTER <= SYSDATE)
LEFT JOIN TGFCTT CTT ON CTT.CODCONTATO = CAB.CODCONTATO AND CTT.CODPARC = CAB.CODPARC
WHERE OS.ID = (SELECT C2.ID
                FROM AD_CONTROLEOS C1
                INNER JOIN AD_CONTROLEOS C2 ON C2.NUOS = C1.NUOS
                AND C2.REVISAO = (SELECT MAX(C3.REVISAO) FROM AD_CONTROLEOS C3 WHERE C3.NUOS = C1.NUOS)
                WHERE C1.ID = $P{PK_ID})
ORDER BY OS.NUOS ASC]]>
	</queryString>
