<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Itens" language="groovy" pageWidth="802" pageHeight="555" orientation="Landscape" columnWidth="802" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.7715610000000017"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="ireport.definition"/>
	<parameter name="ID" class="java.math.BigDecimal" isForPrompting="false"/>
	<queryString>
		<![CDATA[WITH DADOS AS(
SELECT
    ROW_NUMBER() OVER (ORDER BY T.ORDEM) AS REFERENCIA,
    T.*
FROM (
    SELECT
        CASE WHEN P.DECISAO = 6 THEN 0 ELSE P.ORDEM END AS ORDEM,
        CASE
            WHEN P.DECISAO = 6 THEN 'MÃO DE OBRA MONTAGEM/TESTE'
            WHEN P.DECISAO IN (2, 5) THEN 'SUBSTITUIR - ' || UPPER(MAX(G.DESCRGRUPOPROD))
            ELSE UPPER(MAX(D.DESCR)) || ' - ' || UPPER(MAX(G.DESCRGRUPOPROD))
        END AS DESCRICAO,
        ' ' AS NCM,
        CASE WHEN P.DECISAO = 6 THEN 1 ELSE MAX(P.QTD) END AS QTD,
        SUM(
            CASE
                WHEN P.DECISAO IN (2, 5) THEN 0
                WHEN P.TIPPRECO = 1 THEN NVL(P.VLRTOTVENDA, 0)
                ELSE NVL(P.VLRVENDAMANUAL, 0)
            END
        ) AS VLRTOT,
        0 AS CODPROD,
        OS.PERCDESCSER
    FROM AD_PARTNAME P
    INNER JOIN AD_CONTROLEOS OS ON OS.ID = P.ID
    LEFT JOIN TGFGRU G ON G.CODGRUPOPROD = P.PARTNAME
    LEFT JOIN AD_TIPDECISAO D ON D.CODDESC = P.DECISAO
    WHERE P.ID = $P{ID}
      AND P.COBRACLIENTE = 'S'
      AND P.DECISAO IN (2, 3, 4, 5, 6)
    GROUP BY
        P.DECISAO,
        CASE WHEN P.DECISAO = 6 THEN 0 ELSE P.ORDEM END,
        -- Agrupamos pelo CODPARTNAME apenas se NÃO for mão de obra,
        -- para garantir que a mão de obra some tudo e os outros fiquem separados.
        CASE WHEN P.DECISAO = 6 THEN 0 ELSE P.CODPARTNAME END,
        OS.PERCDESCSER
) T
ORDER BY T.ORDEM)
SELECT
  D.REFERENCIA,
  D.ORDEM,
  D.DESCRICAO,
  D.NCM,
  D.QTD,
  D.VLRTOT,
  D.CODPROD,
  D.PERCDESCSER,
  ROUND((D.VLRTOT * (1 - (NVL(D.PERCDESCSER, 0) / 100))),2) AS VLRTOTLIQ,
  (D.VLRTOT - (ROUND((D.VLRTOT * (1 - (NVL(D.PERCDESCSER, 0) / 100))),2))) AS VLRDESC
FROM DADOS D]]>
	</queryString>
	<field name="REFERENCIA" class="java.math.BigDecimal"/>
	<field name="ORDEM" class="java.math.BigDecimal"/>
	<field name="DESCRICAO" class="java.lang.String"/>
	<field name="NCM" class="java.lang.String"/>
	<field name="QTD" class="java.math.BigDecimal"/>
	<field name="VLRTOT" class="java.math.BigDecimal"/>
	<field name="CODPROD" class="java.math.BigDecimal"/>
	<field name="PERCDESCSER" class="java.math.BigDecimal"/>
	<field name="VLRTOTLIQ" class="java.math.BigDecimal"/>
	<field name="VLRDESC" class="java.math.BigDecimal"/>
	<variable name="VLRTOT_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{VLRTOT}]]></variableExpression>
	</variable>
	<variable name="VLRTOTDESC" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{VLRDESC}]]></variableExpression>
	</variable>
	<variable name="VLRTOTLIQ" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{VLRTOTLIQ}]]></variableExpression>
	</variable>
