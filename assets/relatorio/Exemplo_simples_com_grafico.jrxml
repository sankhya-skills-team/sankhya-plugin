<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Pratica03" language="groovy" pageWidth="800" pageHeight="842" columnWidth="800" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" isIgnorePagination="true">
	<property name="ireport.zoom" value="1.771561000000014"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="P_DTINI" class="java.sql.Timestamp">
		<parameterDescription><![CDATA[Data Inicial]]></parameterDescription>
	</parameter>
	<parameter name="P_DTDFINAL" class="java.sql.Timestamp">
		<parameterDescription><![CDATA[Data Final]]></parameterDescription>
	</parameter>
	<parameter name="P_CODNAT" class="java.math.BigDecimal">
		<property name="nomeTabela" value="TGFNAT"/>
		<parameterDescription><![CDATA[Natureza]]></parameterDescription>
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="P_CODCID" class="java.math.BigDecimal">
		<property name="nomeTabela" value="TSICID"/>
		<parameterDescription><![CDATA[Cidade]]></parameterDescription>
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="P_CODPARC" class="java.math.BigDecimal">
		<property name="nomeTabela" value="TGFPAR"/>
		<parameterDescription><![CDATA[Parceiro]]></parameterDescription>
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    SUM(CAB.VLRNOTA) AS VLRNOTA,
    CAB.CODPARC,
    PAR.NOMEPARC,
    TO_CHAR(CAB.DTNEG,'DD/MM/YYYY') AS DTNEG,
    CAB.CODNAT,
    NAT.DESCRNAT,
    (CASE WHEN TPV.DESCRTIPVENDA = ' ' THEN 'Sem Informações'ELSE TPV.DESCRTIPVENDA END) as DESCRTIPVENDA,
    PAR.CODCID,
    CID.NOMECID

FROM TGFCAB CAB
INNER JOIN TSIEMP EMP ON CAB.CODEMP = EMP.CODEMP
INNER JOIN TGFPAR PAR ON CAB.CODPARC = PAR.CODPARC
INNER JOIN TGFNAT NAT ON CAB.CODNAT = NAT.CODNAT
INNER JOIN TSICUS CUS ON CAB.CODCENCUS = CUS.CODCENCUS
INNER JOIN TGFTPV TPV ON CAB.CODTIPVENDA = TPV.CODTIPVENDA
INNER JOIN TSICID CID ON PAR.CODCID = CID.CODCID

WHERE CAB.DTNEG BETWEEN $P{P_DTINI} AND $P{P_DTDFINAL}
AND (PAR.NOMEPARC = $P{P_CODPARC} OR $P{P_CODPARC} IS NULL)
AND (CAB.CODNAT = $P{P_CODNAT} OR $P{P_CODNAT} IS NULL)
AND (PAR.CODCID = $P{P_CODCID} OR $P{P_CODCID} IS NULL)

GROUP BY
    CAB.CODPARC,
    PAR.NOMEPARC,
    "DTNEG",
    NAT.DESCRNAT,
    CAB.CODNAT,
    "DESCRTIPVENDA",
    PAR.CODCID,
    CID.NOMECID
ORDER BY "DESCRTIPVENDA"]]>
	</queryString>
	<field name="VLRNOTA" class="java.math.BigDecimal"/>
	<field name="CODPARC" class="java.math.BigDecimal"/>
	<field name="NOMEPARC" class="java.lang.String"/>
	<field name="DTNEG" class="java.lang.String"/>
	<field name="CODNAT" class="java.math.BigDecimal"/>
	<field name="DESCRNAT" class="java.lang.String"/>
	<field name="DESCRTIPVENDA" class="java.lang.String"/>
	<field name="CODCID" class="java.math.BigDecimal"/>
	<field name="NOMECID" class="java.lang.String"/>
	<variable name="V_VLRNOTATOTAL" class="java.lang.Float" calculation="Sum">
		<variableExpression><![CDATA[$F{VLRNOTA}.floatValue()]]></variableExpression>
	</variable>
	<variable name="V_CONTADOR" class="java.lang.Integer" resetType="Group" resetGroup="Tipo de venda" calculation="Count">
