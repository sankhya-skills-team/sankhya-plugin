<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="FolhaPagamento" pageWidth="21600" pageHeight="10000" orientation="Landscape" columnWidth="21560" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="0.42409761837248483"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="ireport.definition"/>
	<style name="Crosstab Data Text" hAlign="Center"/>
	<parameter name="P_CODEMP" class="java.math.BigDecimal">
		<property name="nomeTabela" value="TSIEMP"/>
		<parameterDescription><![CDATA[Empresa]]></parameterDescription>
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="P_CODDEP" class="java.math.BigDecimal">
		<property name="nomeTabela" value="TFPDEP"/>
		<parameterDescription><![CDATA[Departamento]]></parameterDescription>
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="P_CODFUNC" class="java.math.BigDecimal">
		<property name="nomeTabela" value="TFPFUN"/>
		<parameterDescription><![CDATA[Funcionário]]></parameterDescription>
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="P_TIPFOLHA" class="java.lang.String">
		<parameterDescription><![CDATA[Tipo de Folha]]></parameterDescription>
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="P_REFERENCIA" class="java.sql.Timestamp">
		<parameterDescription><![CDATA[Referência]]></parameterDescription>
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    EMP.CODEMP,
    EMP.RAZAOSOCIAL,
    EMP.CGC,

    FOL.REFERENCIA,
    BAS.DTPAGAMENTO,

    FOL.CODFUNC,
    FUN.NOMEFUNC,
    FUN.CPF,
    FUN.CODSIND,

    CAR.DESCRCARGO,

    FUN.CODDEP,
    DEP.DESCRDEP,

    FUN.DTADM,
    FUN.DTDEM,

    F_DESCROPC('TFPFUN','SITUACAO',FUN.SITUACAO) AS SITUACAO,

    FUN.CAUSAAFAST,
    (SELECT AFA1.DESCRAFAST
       FROM TFPAFA AFA1
      WHERE AFA1.CODAFAST = FUN.CAUSAAFAST
        AND TIPTAB = 'C') AS DESCRAFAST,

    FUN.AFASTFGTS,
    (SELECT AFA2.DESCRAFAST
       FROM TFPAFA AFA2
      WHERE AFA2.CODAFAST = FUN.AFASTFGTS
        AND TIPTAB = 'F') AS MOTFGTS,

    FUN.AFASTRAIS,
    (SELECT AFA3.DESCRAFAST
       FROM TFPAFA AFA3
      WHERE AFA3.CODAFAST = FUN.AFASTRAIS
        AND TIPTAB = 'R') AS MOTRAIS,

    CASE FOL.TIPFOLHA
        WHEN 'A' THEN 'Adiantamento'
        WHEN 'N' THEN 'Mensal'
        WHEN 'R' THEN 'Rescisão'
        WHEN 'F' THEN 'Férias'
        WHEN 'D' THEN '13º Salário'
        WHEN 'C' THEN 'Rescisão Complementar'
        WHEN 'L' THEN 'Resilição'
        WHEN 'O' THEN 'Folha Complementar'
        WHEN 'P' THEN 'Pensionista'
        WHEN 'U' THEN 'PLR'
        ELSE FOL.TIPFOLHA
    END AS TIPFOLHA,

    EVE.CODEVENTO,
    EVE.DESCREVENTO,

    BAS.SALBRUTO,
    BAS.SALLIQ,
    (BAS.SALBRUTO - BAS.SALLIQ) AS TOTALDESCONTOS,
    BAS.SALBASE,

    CASE
        WHEN EVE.TIPEVENTO = -1 THEN 2
        WHEN EVE.TIPEVENTO = 0  THEN 3
        ELSE EVE.TIPEVENTO
    END AS TIPEVENTO,

    EVE.BASELIQUIDO,

    /* SOMA DOS VALORES DO EVENTO */
    SUM(FOL.VLREVENTO) AS VLREVENTO,

    (SELECT PAR.CODPARC
       FROM TGFPAR PAR
      WHERE PAR.CODPARC = DEP.CODPARC) AS PARCEIRO_DEP,

    (SELECT CUS.CODCENCUS
       FROM TSICUS CUS
      WHERE CUS.CODCENCUS = DEP.CODCENCUS) AS CENTRO_RESULTADO,

    (SELECT CUS.DESCRCENCUS
       FROM TSICUS CUS
      WHERE CUS.CODCENCUS = DEP.CODCENCUS) AS DESCRCENCUS

FROM TFPFOL FOL

INNER JOIN TFPFUN FUN
        ON FUN.CODEMP  = FOL.CODEMP
       AND FUN.CODFUNC = FOL.CODFUNC

INNER JOIN TFPEVE EVE
        ON EVE.CODEVENTO   = FOL.CODEVENTO
       AND EVE.TIPEVENTO   = FOL.TIPEVENTO
       AND EVE.IMPHOLLERIT = 'S'

INNER JOIN TSIEMP EMP
        ON EMP.CODEMP = FOL.CODEMP

INNER JOIN TFPBAS BAS
        ON BAS.CODEMP     = FOL.CODEMP
       AND BAS.CODFUNC    = FOL.CODFUNC
       AND BAS.TIPFOLHA   = FOL.TIPFOLHA
       AND BAS.REFERENCIA = FOL.REFERENCIA

LEFT JOIN TFPHFU FU
       ON FU.CODEMP     = FUN.CODEMP
      AND FU.CODFUNC    = FUN.CODFUNC
      AND FU.REFERENCIA = FOL.REFERENCIA

LEFT JOIN TFPCAR CAR
       ON CAR.CODCARGO = COALESCE(FU.CODCARGO, FUN.CODCARGO)

INNER JOIN TFPDEP DEP
        ON DEP.CODDEP = COALESCE(FU.CODDEP, FUN.CODDEP)

WHERE FOL.CODEMP     = $P{P_CODEMP}
  AND FOL.REFERENCIA = $P{P_REFERENCIA}
  AND FOL.TIPFOLHA   = $P{P_TIPFOLHA}
  AND ($P{P_CODDEP}  IS NULL OR FUN.CODDEP  = $P{P_CODDEP})
  AND ($P{P_CODFUNC} IS NULL OR FOL.CODFUNC = $P{P_CODFUNC})

GROUP BY
    EMP.CODEMP,
    EMP.RAZAOSOCIAL,
    EMP.CGC,
    FOL.REFERENCIA,
    BAS.DTPAGAMENTO,
    FOL.CODFUNC,
    FUN.NOMEFUNC,
    FUN.CPF,
    FUN.CODSIND,
    CAR.DESCRCARGO,
    FUN.CODDEP,
    DEP.DESCRDEP,
    FUN.DTADM,
    FUN.DTDEM,
    FUN.SITUACAO,
    FUN.CAUSAAFAST,
    FUN.AFASTFGTS,
    FUN.AFASTRAIS,
    FOL.TIPFOLHA,
    EVE.CODEVENTO,
    EVE.DESCREVENTO,
    BAS.SALBRUTO,
    BAS.SALLIQ,
    BAS.SALBASE,
    EVE.TIPEVENTO,
    EVE.BASELIQUIDO,
    DEP.CODPARC,
    DEP.CODCENCUS

ORDER BY
    EMP.CODEMP,
    TIPFOLHA,
    FOL.CODFUNC,
    TIPEVENTO,
    EVE.CODEVENTO]]>
	</queryString>
