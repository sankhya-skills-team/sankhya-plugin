<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Itens_mat" language="groovy" pageWidth="802" pageHeight="555" orientation="Landscape" columnWidth="802" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="ireport.definition"/>
	<parameter name="ID" class="java.math.BigDecimal" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[WITH SERVICOS AS (
    SELECT
        ROW_NUMBER() OVER (ORDER BY T.ORDEM) AS REFERENCIA,
        T.*
    FROM (
        -- SERVICO MAO DE OBRA
        SELECT 0 AS ORDEM, 'MÃO DE OBRA MONTAGEM/TESTE' AS DESCRICAO, ' ' AS NCM, 1 AS QTD,
               SUM(CASE WHEN TIPPRECO = 1 THEN NVL(VLRTOTVENDA, 0) ELSE NVL(VLRVENDAMANUAL, 0) END) AS VLRTOT,
               0 AS CODPROD, NULL AS ID_PK -- Adicionei uma referência nula para o union
        FROM AD_PARTNAME P WHERE P.ID = $P{ID} AND P.DECISAO = 6 AND P.COBRACLIENTE = 'S'

        UNION ALL

        -- SERVICO SUBSTITUICAO/PRODUTO ADICIONAL
        SELECT P.ORDEM, 'SUBSTITUIR - ' || UPPER(G.DESCRGRUPOPROD), ' ', QTD, 0, 0, P.CODPARTNAME
        FROM AD_PARTNAME P
        LEFT JOIN TGFGRU G ON G.CODGRUPOPROD = P.PARTNAME
        WHERE P.ID = $P{ID} AND P.DECISAO IN (2, 5) AND P.COBRACLIENTE = 'S'

        UNION ALL

        -- SERVICO RECUPERACAO/SERVICO ADICIONAL
        SELECT P.ORDEM, UPPER(D.DESCR) || ' - ' || UPPER(G.DESCRGRUPOPROD), ' ', QTD,
               CASE WHEN TIPPRECO = 1 THEN NVL(VLRTOTVENDA, 0) ELSE NVL(VLRVENDAMANUAL, 0) END,
               0, P.CODPARTNAME
        FROM AD_PARTNAME P
        LEFT JOIN TGFGRU G ON G.CODGRUPOPROD = P.PARTNAME
        LEFT JOIN AD_TIPDECISAO D ON D.CODDESC = P.DECISAO
        WHERE P.ID = $P{ID} AND P.DECISAO IN (3, 4) AND P.COBRACLIENTE = 'S'
    ) T
)

-- AGORA BUSCAMOS OS MATERIAIS USANDO A REFERENCIA DOS SERVIÇOS
SELECT
    S.REFERENCIA, -- Aqui traz o 1, 2, 3... da query anterior
    S.ORDEM,
    P.DESCRPROD AS DESCRICAO,
    P.NCM,
    M.QUANTIDADE AS QTD,
    ROUND(M.VLRVENDAUNT / (SELECT SUM(VLRVENDAUNT) FROM AD_MATERIAIS WHERE ID = M.ID AND CODPARTNAME = M.CODPARTNAME) *
    CASE WHEN N.TIPPRECO = 1 THEN NVL(N.VLRTOTVENDA, 0)
         ELSE NVL(N.VLRVENDAMANUAL, 0)
         END, 2) AS VLRTOTAL,
    M.CODPRODUTO AS CODPROD,
    OS.PERCDESCMAT,

    ROUND(((ROUND(M.VLRVENDAUNT / (SELECT SUM(VLRVENDAUNT) FROM AD_MATERIAIS WHERE ID = M.ID AND CODPARTNAME = M.CODPARTNAME) *
    CASE WHEN N.TIPPRECO = 1 THEN NVL(N.VLRTOTVENDA, 0)
         ELSE NVL(N.VLRVENDAMANUAL, 0)
         END, 2)) * (1 - (NVL(OS.PERCDESCMAT, 0) / 100))),2) AS VLRTOTLIQ,

    (ROUND(M.VLRVENDAUNT / (SELECT SUM(VLRVENDAUNT) FROM AD_MATERIAIS WHERE ID = M.ID AND CODPARTNAME = M.CODPARTNAME) *
    CASE WHEN N.TIPPRECO = 1 THEN NVL(N.VLRTOTVENDA, 0)
         ELSE NVL(N.VLRVENDAMANUAL, 0)
         END, 2)) -
    (ROUND(((ROUND(M.VLRVENDAUNT / (SELECT SUM(VLRVENDAUNT) FROM AD_MATERIAIS WHERE ID = M.ID AND CODPARTNAME = M.CODPARTNAME) *
    CASE WHEN N.TIPPRECO = 1 THEN NVL(N.VLRTOTVENDA, 0)
         ELSE NVL(N.VLRVENDAMANUAL, 0)
         END, 2)) * (1 - (NVL(OS.PERCDESCMAT, 0) / 100))),2)) AS VLRDESC

FROM AD_MATERIAIS M
INNER JOIN AD_PARTNAME N ON N.CODPARTNAME = M.CODPARTNAME AND N.ID = M.ID
INNER JOIN AD_CONTROLEOS OS ON OS.ID = N.ID
INNER JOIN SERVICOS S ON S.ID_PK = N.CODPARTNAME -- Join crucial para pegar a REFERENCIA correta
LEFT JOIN TGFPRO P ON P.CODPROD = M.CODPRODUTO
WHERE M.ID = $P{ID}
AND N.DECISAO IN (2, 5)
AND N.COBRACLIENTE = 'S'
ORDER BY S.REFERENCIA, M.CODPRODUTO]]>
	</queryString>
	<field name="REFERENCIA" class="java.math.BigDecimal"/>
	<field name="ORDEM" class="java.math.BigDecimal"/>
	<field name="DESCRICAO" class="java.lang.String"/>
	<field name="NCM" class="java.lang.String"/>
	<field name="QTD" class="java.math.BigDecimal"/>
	<field name="VLRTOTAL" class="java.math.BigDecimal"/>
	<field name="CODPROD" class="java.math.BigDecimal"/>
	<field name="PERCDESCMAT" class="java.math.BigDecimal"/>
	<field name="VLRTOTLIQ" class="java.math.BigDecimal"/>
	<field name="VLRDESC" class="java.math.BigDecimal"/>
	<variable name="VLRTOTAL_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{VLRTOTAL}]]></variableExpression>
	</variable>
	<variable name="VLRTOTDESC" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{VLRDESC}]]></variableExpression>
	</variable>
	<variable name="VLRTOTLIQ" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{VLRTOTLIQ}]]></variableExpression>
	</variable>
