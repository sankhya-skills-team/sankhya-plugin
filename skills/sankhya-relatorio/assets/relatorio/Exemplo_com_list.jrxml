				<imageExpression class="java.io.InputStream"><![CDATA[$F{IMG03}]]></imageExpression>
			</image>
		</band>
		<band height="100" splitType="Prevent">
			<printWhenExpression><![CDATA[$F{IMG04} != null]]></printWhenExpression>
			<image scaleImage="FillFrame" onErrorType="Blank">
				<reportElement positionType="Float" x="4" y="4" width="122" height="96"/>
				<imageExpression class="java.io.InputStream"><![CDATA[$F{IMG04}]]></imageExpression>
			</image>
		</band>
		<band height="96" splitType="Prevent">
			<printWhenExpression><![CDATA[$F{IMG05} != null]]></printWhenExpression>
			<image scaleImage="FillFrame" onErrorType="Blank">
				<reportElement positionType="Float" x="3" y="0" width="122" height="96"/>
				<imageExpression class="java.io.InputStream"><![CDATA[$F{IMG05}]]></imageExpression>
			</image>
		</band>
		<band height="96" splitType="Prevent">
			<printWhenExpression><![CDATA[$F{IMG06} != null]]></printWhenExpression>
			<image scaleImage="FillFrame" onErrorType="Blank">
				<reportElement positionType="Float" x="4" y="0" width="122" height="96"/>
				<imageExpression class="java.io.InputStream"><![CDATA[$F{IMG06}]]></imageExpression>
			</image>
		</band>
		<band height="100" splitType="Prevent">
			<printWhenExpression><![CDATA[$F{IMG07} != null]]></printWhenExpression>
			<image scaleImage="FillFrame" onErrorType="Blank">
				<reportElement positionType="Float" x="4" y="0" width="122" height="96"/>
				<imageExpression class="java.io.InputStream"><![CDATA[$F{IMG07}]]></imageExpression>
			</image>
		</band>
		<band height="100" splitType="Prevent">
			<printWhenExpression><![CDATA[$F{IMG08} != null]]></printWhenExpression>
			<image scaleImage="FillFrame" onErrorType="Blank">
				<reportElement positionType="Float" x="4" y="0" width="122" height="96"/>
				<imageExpression class="java.io.InputStream"><![CDATA[$F{IMG08}]]></imageExpression>
			</image>
		</band>
		<band height="100" splitType="Prevent">
			<printWhenExpression><![CDATA[$F{IMG09} != null]]></printWhenExpression>
			<image scaleImage="FillFrame" onErrorType="Blank">
				<reportElement positionType="Float" x="3" y="4" width="122" height="96"/>
				<imageExpression class="java.io.InputStream"><![CDATA[$F{IMG09}]]></imageExpression>
			</image>
		</band>
		<band height="101" splitType="Prevent">
			<printWhenExpression><![CDATA[$F{IMG10} != null]]></printWhenExpression>
			<image scaleImage="FillFrame" onErrorType="Blank">
				<reportElement positionType="Float" x="4" y="1" width="122" height="96"/>
				<imageExpression class="java.io.InputStream"><![CDATA[$F{IMG10}]]></imageExpression>
			</image>
		</band>
	</detail>
	<pageFooter>
		<band height="55">
			<image scaleImage="FillFrame" hAlign="Center" onErrorType="Blank">
				<reportElement x="-85" y="0" width="595" height="55"/>
				<imageExpression class="java.io.InputStream"><![CDATA[$F{RODAPE} == null ? null : ((java.sql.Blob)$F{RODAPE}).getBinaryStream()]]></imageExpression>
			</image>
		</band>
	</pageFooter>
	<lastPageFooter>
		<band height="136" splitType="Stretch">
			<componentElement>
				<reportElement positionType="Float" x="0" y="5" width="454" height="60"/>
				<jr:list xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd" printOrder="Horizontal">
					<datasetRun subDataset="dataset1">
						<datasetParameter name="PK_SEQUENCIA">
							<datasetParameterExpression><![CDATA[$F{SEQUENCIA}]]></datasetParameterExpression>
						</datasetParameter>
						<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
					</datasetRun>
					<jr:listContents height="38" width="227">
						<textField isStretchWithOverflow="true">
							<reportElement x="0" y="0" width="220" height="38"/>
							<textElement>
								<font fontName="Times New Roman" size="11"/>
							</textElement>
							<textFieldExpression class="java.lang.String"><![CDATA[$F{ASSINATURAS}+"\n"+$F{AD_FUNCAO}+"\nAssociação Brasileira dos Produtores de Algodão"]]></textFieldExpression>
