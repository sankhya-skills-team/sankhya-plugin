<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Pratica_iReport" language="groovy" pageWidth="432" pageHeight="95" orientation="Landscape" columnWidth="418" leftMargin="7" rightMargin="7" topMargin="7" bottomMargin="7">
	<property name="ireport.zoom" value="2.3579476910000023"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="P_CODPROD" class="java.math.BigDecimal">
		<property name="nomeTabela" value="TGFPRO"/>
		<parameterDescription><![CDATA[Produto]]></parameterDescription>
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
	pro.codprod,
	pro.descrprod,
	pro.marca,
	pro.codvol,
	nvl(pro.referencia, 0) as referencia,
	pro.caracteristicas,
	snk_preco(0,pro.codprod) AS preco

FROM tgfpro pro

where pro.codprod = $P{P_CODPROD}]]>
	</queryString>
	<field name="CODPROD" class="java.math.BigDecimal"/>
	<field name="DESCRPROD" class="java.lang.String"/>
	<field name="MARCA" class="java.lang.String"/>
	<field name="CODVOL" class="java.lang.String"/>
	<field name="REFERENCIA" class="java.lang.String"/>
	<field name="CARACTERISTICAS" class="java.lang.String"/>
	<field name="PRECO" class="java.math.BigDecimal"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="63" splitType="Stretch">
			<textField>
				<reportElement x="0" y="0" width="216" height="20"/>
				<textElement>
					<font size="14"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{CODPROD}+" - "+$F{DESCRPROD}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="21" y="43" width="100" height="20"/>
				<textElement>
					<font size="14"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{REFERENCIA}]]></textFieldExpression>
			</textField>
			<componentElement>
				<reportElement x="0" y="23" width="168" height="20"/>
				<jr:barbecue xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd" type="Codabar" drawText="false" checksumRequired="false">
					<jr:codeExpression><![CDATA[$F{REFERENCIA}]]></jr:codeExpression>
				</jr:barbecue>
			</componentElement>
			<textField>
				<reportElement x="338" y="0" width="80" height="20"/>
				<textElement/>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{CODVOL}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="318" y="43" width="100" height="20"/>
				<textElement>
					<font size="14" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{PRECO}]]></textFieldExpression>
			</textField>
			<image>
				<reportElement x="196" y="0" width="122" height="63"/>
				<imageExpression class="java.awt.Image"><![CDATA[com.google.zxing.client.j2se.MatrixToImageWriter.toBufferedImage(new com.google.zxing.qrcode.QRCodeWriter().encode($F{CARACTERISTICAS}, com.google.zxing.BarcodeFormat.QR_CODE,300,300))]]></imageExpression>
			</image>
		</band>
	</detail>
</jasperReport>
